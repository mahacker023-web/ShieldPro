<Window x:Class="AppBlocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShieldPro - Corporate Blocker" Height="550" Width="800"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

    <Border Background="#FAF9F6" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Win 11 Header -->
            <Grid Grid.Row="0" Background="#F0F0F0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <TextBlock Text="🛡️ ShieldPro Corporate System Blocker" FontSize="13" FontWeight="Bold" Foreground="#222222"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="—" Click="Minimize_Click" Background="Transparent" Foreground="#555555" Width="40" Height="42"/>
                    <Button Content="✕" Click="Close_Click" Background="Transparent" Foreground="#E81123" Width="40" Height="42"/>
                </StackPanel>
            </Grid>

            <!-- Body Container -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar Navigation -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <Button x:Name="BtnWeb" Content="🌐 Website Blocker" Click="NavWeb_Click" Margin="0,0,0,10" Background="#E5E5E5" Foreground="#1A1A1A"/>
                    <Button x:Name="BtnApp" Content="🚫 App Blocker" Click="NavApp_Click" Margin="0,0,0,10" Background="Transparent" Foreground="#1A1A1A"/>
                    <Button x:Name="BtnAbout" Content="👨‍💻 About Developer" Click="NavAbout_Click" Margin="0,0,0,10" Background="Transparent" Foreground="#1A1A1A"/>
                </StackPanel>

                <!-- Main Content Panes -->
                <Grid Grid.Column="1">
                    
                    <!-- Tab 1: Web Blocker -->
                    <Border x:Name="TabWeb" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Website Restrictions" FontSize="18" FontWeight="Bold" Foreground="#0067C0" Margin="0,0,0,8"/>
                            <TextBlock Text="Block adult sites or custom URLs across all browsers." Foreground="#666666" Margin="0,0,0,15"/>

                            <CheckBox x:Name="ChkAdultBlock" Content="Block Adult Websites (pornhub.com, etc.)" FontSize="13" Margin="0,6" IsChecked="True"/>
                            
                            <TextBlock Text="Custom Domain to Block:" FontSize="12" Margin="0,15,0,5" Foreground="#333"/>
                            <TextBox x:Name="TxtCustomDomain" Height="32" Padding="8,4" VerticalContentAlignment="Center" Text="facebook.com"/>
                            
                            <Button Content="Apply Web Restrictions" Click="ApplyWebGuard_Click" Margin="0,20,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab 2: App Blocker -->
                    <Border x:Name="TabApp" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Application Process Guard" FontSize="18" FontWeight="Bold" Foreground="#0067C0" Margin="0,0,0,8"/>
                            <TextBlock Text="Prevent selected programs from running on this PC." Foreground="#666666" Margin="0,0,0,15"/>

                            <CheckBox x:Name="ChkBlockChromeApp" Content="Block Google Chrome (chrome.exe)" FontSize="13" Margin="0,6" IsChecked="True"/>
                            <CheckBox x:Name="ChkBlockIDM" Content="Block Internet Download Manager (idman.exe)" FontSize="13" Margin="0,6" IsChecked="True"/>

                            <Button x:Name="BtnToggleApp" Content="Start Guarding Service" Click="ToggleAppService_Click" Margin="0,20,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab 3: About Developer -->
                    <Border x:Name="TabAbout" Background="White" CornerRadius="8" Padding="25" BorderBrush="#E0E0E0" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border CornerRadius="40" Width="80" Height="80" Background="#0067C0" Margin="0,0,0,12">
                                <TextBlock Text="M" Foreground="White" FontSize="38" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Mubashir" FontSize="22" FontWeight="Bold" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                            <TextBlock Text="Lead Software Engineer" FontSize="13" Foreground="#0067C0" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,12"/>

                            <TextBlock Text="ShieldPro Corporate Blocker v1.0" FontSize="12" Foreground="#777777" HorizontalAlignment="Center"/>
                            <TextBlock Text="Built with C# &amp; Win11 Fluent UI Framework." FontSize="11" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
