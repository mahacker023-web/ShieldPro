<Window x:Class="AppBlocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShieldPro - Corporate Guard" Height="600" Width="850"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

    <Border Background="#FAF9F6" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Win 11 Header Bar -->
            <Grid Grid.Row="0" Background="#F0F0F0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <TextBlock Text="🛡️ ShieldPro Corporate Security Suite" FontSize="13" FontWeight="Bold" Foreground="#222222"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="—" Click="Minimize_Click" Background="Transparent" Foreground="#555555" Width="40" Height="42"/>
                    <Button Content="✕" Click="Close_Click" Background="Transparent" Foreground="#E81123" Width="40" Height="42"/>
                </StackPanel>
            </Grid>

            <!-- Main Body Layout -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar Navigation -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <Button x:Name="BtnWeb" Content="🌐 Web &amp; App Shield" Click="NavWeb_Click" Margin="0,0,0,10" Background="#E5E5E5" Foreground="#1A1A1A"/>
                    <Button x:Name="BtnSettings" Content="⚙️ Security Settings" Click="NavSettings_Click" Margin="0,0,0,10" Background="Transparent" Foreground="#1A1A1A"/>
                    <Button x:Name="BtnAbout" Content="👨‍💻 About Developer" Click="NavAbout_Click" Margin="0,0,0,10" Background="Transparent" Foreground="#1A1A1A"/>
                </StackPanel>

                <!-- Main Content Panes -->
                <Grid Grid.Column="1">
                    
                    <!-- Tab 1: Shielding Controls -->
                    <Border x:Name="TabWeb" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="System Shielding" FontSize="18" FontWeight="Bold" Foreground="#0067C0" Margin="0,0,0,5"/>
                            <TextBlock Text="Protect your environment from restricted content and apps." Foreground="#666666" Margin="0,0,0,15"/>

                            <CheckBox x:Name="ChkAdultBlock" Content="Block Adult Content (Pornhub, etc.)" FontSize="13" Margin="0,5" IsChecked="True"/>
                            <CheckBox x:Name="ChkLockApps" Content="Enable Password Guard for Blocked Apps" FontSize="13" Margin="0,5" IsChecked="True"/>

                            <TextBlock Text="Active Blocked Apps &amp; Domains:" FontSize="13" FontWeight="SemiBold" Margin="0,15,0,5" Foreground="#333"/>
                            <ListBox x:Name="LstTargets" Height="140" BorderBrush="#E0E0E0" CornerRadius="4" Padding="5"/>

                            <Button x:Name="BtnToggleGuard" Content="Activate Protection Guard" Click="ToggleGuard_Click" Margin="0,15,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab 2: Security Settings -->
                    <Border x:Name="TabSettings" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Security Configuration" FontSize="18" FontWeight="Bold" Foreground="#0067C0" Margin="0,0,0,5"/>
                            <TextBlock Text="Manage master password and add custom target apps/URLs." Foreground="#666666" Margin="0,0,0,15"/>

                            <TextBlock Text="Master Password:" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <PasswordBox x:Name="TxtMasterPassword" Password="1234" Height="32" Padding="6,2" Margin="0,4,0,15"/>

                            <TextBlock Text="Add Custom App Process Name (e.g., vlc, notepad):" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <Grid Margin="0,4,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtNewTarget" Height="32" Padding="6,2" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="Add Item" Click="AddTarget_Click" Margin="10,0,0,0"/>
                            </Grid>

                            <Button Content="Save Security Settings" Click="SaveSettings_Click" HorizontalAlignment="Left" Background="#0B6623"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab 3: About Developer -->
                    <Border x:Name="TabAbout" Background="White" CornerRadius="8" Padding="25" BorderBrush="#E0E0E0" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border CornerRadius="40" Width="80" Height="80" Background="#0067C0" Margin="0,0,0,12">
                                <TextBlock Text="M" Foreground="White" FontSize="38" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Mubashir" FontSize="22" FontWeight="Bold" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                            <TextBlock Text="Software Developer &amp; UI Architect" FontSize="13" Foreground="#0067C0" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,15"/>

                            <Border Background="#F4F6F8" CornerRadius="6" Padding="15" Margin="0,5,0,15" Width="400">
                                <TextBlock Text="&quot;Thank you for using ShieldPro! Wishing all users a secure, focused, and highly productive digital experience. Stay safe and keep building high.&quot;" 
                                           TextWrapping="Wrap" TextAlignment="Center" FontStyle="Italic" Foreground="#555555" FontSize="12"/>
                            </Border>

                            <TextBlock Text="ShieldPro Corporate Edition v2.0" FontSize="11" Foreground="#999999" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
